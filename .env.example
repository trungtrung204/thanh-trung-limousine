# Production database, for example Supabase/Neon PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth/session secrets. Generate strong random values before production.
AUTH_SECRET="replace-with-random-secret"
ADMIN_EMAIL="admin@example.com"

# Public site URL after deploy.
NEXT_PUBLIC_SITE_URL="https://example.com"

# Payment provider keys, when QR demo is replaced by real payment.
PAYMENT_PROVIDER="demo"
PAYMENT_SECRET_KEY=""
PAYMENT_WEBHOOK_SECRET=""
