# Supabase PostgreSQL.
# DATABASE_URL should usually be the pooled connection string for the app/runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL should be the direct database connection for Prisma migrations/db push.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# JWT secret for future auth work. Generate a strong random value before production.
JWT_SECRET="replace-with-random-secret"

# Public app URL after deploy.
NEXT_PUBLIC_APP_URL="https://example.com"

# Demo admin seed. Run `npm run db:seed:admin` after setting DATABASE_URL.
ADMIN_EMAIL="admin@thanhtrung.local"
ADMIN_PASSWORD="123456"

# Payment provider keys, when QR demo is replaced by real payment.
PAYMENT_PROVIDER="demo"
PAYMENT_SECRET_KEY=""
PAYMENT_WEBHOOK_SECRET=""
